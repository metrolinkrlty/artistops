#!/bin/sh
# Auto-bump the app version by one hundredth on every commit.
f="src/lib/version.ts"
[ -f "$f" ] || exit 0
cur=$(grep "APP_VERSION" "$f" | grep -oE '[0-9]+\.[0-9]+' | head -1)
[ -z "$cur" ] && exit 0
new=$(awk "BEGIN{printf \"%.2f\", $cur + 0.01}")
sed -i '' "s/\"$cur\"/\"$new\"/" "$f" 2>/dev/null || sed -i "s/\"$cur\"/\"$new\"/" "$f"
git add "$f"
exit 0
