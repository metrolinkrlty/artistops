generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  artistName   String
  isAdmin      Boolean  @default(false)
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Song {
  id            String   @id @default(cuid())
  userId        String?
  title         String
  artist        String
  siteTracks    SiteTrack[]
  writers       String[]
  publishers    String[]
  splits        Json
  isrc          String?
  upc           String?
  releaseDate   DateTime?
  genre         String?
  subgenre      String?  // DistroKid subgenre (only some genres have them, e.g. Electronic)
  bpm           Int?
  key           String?
  lyrics        String?
  notes         String?
  collectionTitle String?  // set when this song also names a collection/group registration (e.g. "Hey Evelyn")
  status        SongStatus @default(DEMO)
  coverArtUrl   String?
  audioFileRef  String?
  metadataFile  String?
  masterFileUrl String?  // external link to the full-quality master (e.g. Google Drive .wav) when it's too large to store in-app
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  distributions Distribution[]
  revenues      Revenue[]
  streamPlays   StreamPlay[]
  socialPosts   SocialPost[]
  adCampaigns   AdCampaign[]
  pixelEvents   PixelEvent[]
  @@index([userId])
}

enum SongStatus {
  DEMO
  MIXED
  MASTERED
  RELEASED
  REGISTERED
  MONETIZED
}

model Copyright {
  id                 String   @id @default(cuid())
  userId             String?
  songIds            String[] // one or more songs covered by this registration
  groupTitle           String?  // optional name for group registrations
  serviceRequestNumber    String?
  serviceRequestUrl       String?
  registrationNumber      String?
  registrationCertUrl     String?
  filingDate         DateTime?
  claimant           String?
  authors            String[]
  workType           String?
  depositNotes       String?
  registeredWithUSCO Boolean  @default(false)
  registeredWithPRO  Boolean  @default(false)
  registeredWithMLC  Boolean  @default(false)
  registeredWithSX   Boolean  @default(false)
  registeredWithDist Boolean  @default(false)
  proName            String?
  documents          String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@index([userId])
}

model Distributor {
  id            String         @id @default(cuid())
  userId        String?
  name          String
  accountId     String?
  email         String?
  website       String?
  notes         String?
  distributions Distribution[]
  revenues      Revenue[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  @@index([userId])
}

model Distribution {
  id            String      @id @default(cuid())
  userId        String?
  songId        String
  song          Song        @relation(fields: [songId], references: [id])
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  releaseId     String?
  upc           String?
  isrc          String?
  stores        String[]
  status        DistributionStatus @default(ACTIVE)
  releaseDate   DateTime?
  takedownDate  DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@index([userId])
}

enum DistributionStatus {
  PENDING
  ACTIVE
  TAKEN_DOWN
}

model Revenue {
  id            String      @id @default(cuid())
  userId        String?
  songId        String?
  song          Song?       @relation(fields: [songId], references: [id])
  distributorId String?
  distributor   Distributor? @relation(fields: [distributorId], references: [id])
  platform      String
  revenueType   RevenueType
  amount        Float
  currency      String      @default("USD")
  period        DateTime
  source        String?
  notes         String?
  createdAt     DateTime    @default(now())
  @@index([userId])
}

enum RevenueType {
  STREAMING
  PRO_ROYALTY
  MECHANICAL
  SOUND_EXCHANGE
  SYNC_LICENSE
  DIRECT_SALE
  YOUTUBE_CONTENT_ID
  TIKTOK
  OTHER
}

model StreamPlay {
  id        String   @id @default(cuid())
  userId    String?
  songId    String
  song      Song     @relation(fields: [songId], references: [id])
  platform  String
  plays     Int
  period    DateTime
  isrc      String?
  source    String?
  createdAt DateTime @default(now())
  @@index([userId])
}

model SocialPost {
  id           String     @id @default(cuid())
  userId       String?
  songId       String?
  song         Song?      @relation(fields: [songId], references: [id])
  platform     String
  status       PostStatus @default(IDEA)
  content      String?
  caption      String?
  hashtags     String[]
  targetAudience String?
  scheduledAt  DateTime?
  postedAt     DateTime?
  campaign     String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@index([userId])
}

enum PostStatus {
  IDEA
  DRAFTED
  SCHEDULED
  POSTED
  BOOSTED
  COMPLETED
}

model AdCampaign {
  id              String   @id @default(cuid())
  userId          String?
  songId          String?
  song            Song?    @relation(fields: [songId], references: [id])
  name            String
  platform        String
  objective       String?
  budget          Float?
  startDate       DateTime?
  endDate         DateTime?
  targetAudience  String?
  creativeAssets  String[]
  landingPage     String?
  pixelEvent      String?
  impressions     Int?
  clicks          Int?
  ctr             Float?
  cpc             Float?
  conversions     Int?
  costPerConv     Float?
  revenueAttributed Float?
  status          CampaignStatus @default(DRAFT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([userId])
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

// A named tracking pixel. Its id is the public token embedded in the snippet,
// so one user can run several (e.g. one per website) and keep the data separate.
model Pixel {
  id        String       @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime     @default(now())
  events    PixelEvent[]
  @@index([userId])
}

model PixelEvent {
  id          String   @id @default(cuid())
  userId      String?
  pixelId     String?
  pixel       Pixel?   @relation(fields: [pixelId], references: [id])
  songId      String?
  song        Song?    @relation(fields: [songId], references: [id])
  visitorId   String
  pageUrl     String
  referrer    String?
  eventType   String
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  createdAt   DateTime @default(now())
  @@index([userId])
  @@index([pixelId])
}

model Contact {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  role      String
  email     String?
  phone     String?
  company   String?
  website   String?
  notes     String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
}

model SmartLink {
  id          String   @id @default(cuid())
  userId      String?
  songId      String?
  slug        String   @unique
  title       String
  artistName  String
  coverArtUrl String?
  platforms   Json
  isActive    Boolean  @default(true)
  gateEmail   Boolean  @default(false) // require an email on the /listen page before revealing the platform links
  clicks      SmartLinkClick[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([userId])
}

model SmartLinkClick {
  id              String    @id @default(cuid())
  userId          String?
  smartLinkId     String
  smartLink       SmartLink @relation(fields: [smartLinkId], references: [id])
  platform        String?
  country         String?
  device          String?
  os              String?
  browser         String?
  referrer        String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  isRepeatVisitor Boolean   @default(false)
  createdAt       DateTime  @default(now())
  @@index([userId])
}

model Playlist {
  id            String       @id @default(cuid())
  userId        String?
  name          String
  platform      String
  playlistId    String?
  type          PlaylistType @default(USER)
  followerCount Int?
  isActive      Boolean      @default(true)
  songs         PlaylistSong[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@index([userId])
}

enum PlaylistType {
  EDITORIAL
  ALGORITHMIC
  USER
}

model PlaylistSong {
  id               String   @id @default(cuid())
  userId           String?
  playlistId       String
  playlist         Playlist @relation(fields: [playlistId], references: [id])
  songId           String
  isrc             String?
  addedAt          DateTime?
  removedAt        DateTime?
  streams          Int?
  estimatedRevenue Float?
  createdAt        DateTime @default(now())
  @@index([userId])
}

model ListenerDemographic {
  id        String   @id @default(cuid())
  userId    String?
  songId    String?
  platform  String
  period    DateTime
  country   String?
  city      String?
  ageGroup  String?
  gender    String?
  device    String?
  os        String?
  streams   Int
  createdAt DateTime @default(now())
  @@index([userId])
}

model Connector {
  id          String          @id @default(cuid())
  userId      String?
  name        String
  type        ConnectorType
  platform    String
  status      ConnectorStatus @default(DISCONNECTED)
  credentials Json?
  lastSync    DateTime?
  config      Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([userId])
}

enum ConnectorType {
  STREAMING
  DISTRIBUTOR
  PRO
  ROYALTY
  ADVERTISING
  ANALYTICS
  CRM
  TICKETING
  MERCH
  EMAIL
}

enum ConnectorStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  SYNCING
}

model RightsDocument {
  id        String   @id @default(cuid())
  userId    String?
  songId    String
  type      String
  title     String
  fileUrl   String?
  parties   String[]
  expiresAt DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
}

model AIInsight {
  id         String   @id @default(cuid())
  userId     String?
  category   String
  title      String
  body       String
  confidence Float?
  actionable Boolean  @default(false)
  dismissed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@index([userId])
}

model Forecast {
  id        String   @id @default(cuid())
  userId    String?
  songId    String?
  metric    String
  period    DateTime
  predicted Float
  actual    Float?
  model     String?
  createdAt DateTime @default(now())
  @@index([userId])
}

model Setting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  updatedAt DateTime @updatedAt
  @@unique([userId, key])
}

// Global (app-wide) key/value settings — editable from the admin panel, read on
// public pages like the sign-in screen. Not per-user (unlike Setting above).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  @@index([userId])
}

// Public-website configuration for an artist. One row per artist site; `slug`
// is the public identifier the website fetches (e.g. "luke-corliss").
// socialLinks is a JSON map like { instagram, spotify, appleMusic, youtube, ... }.
// bio/hero/featuredSongIds/previewSeconds are used by the Phase 2 website CMS.
model ArtistSite {
  id              String   @id @default(cuid())
  userId          String   @unique
  slug            String   @unique
  displayName     String
  tagline         String?
  bio             String?
  location        String?
  heroImageUrl    String?
  heroSubtext     String?  // the longer hero paragraph under the artist name
  themeColor      String?  // accent/highlight hex, e.g. "#e0a530"
  fontFamily      String?  // heading-font key the website applies, e.g. "oswald" | "bebas" | "playfair" | "montserrat" | "lora"
  footerText      String?  // custom line shown in the public site footer
  playerStyle     String   @default("waveform") // music player look: "waveform" | "shade" | "simple" | "classic"
  showStreamLinks Boolean  @default(true)  // show per-song streaming links on the site at all
  showMusicNotes  Boolean  @default(true)  // fly music notes off the waveform player's leading edge while playing
  streamLinksAfterGate Boolean @default(false) // false = show before/always, true = only after the fan unlocks the song
  hiddenSections  String[] @default([]) // section keys to hide, e.g. ["gallery","shows"]
  shows           Json?    // [{date, venue, city?, ticketUrl?}]
  heroCtaPrimary  String?  // label for the primary hero button (default "Listen Now")
  heroCtaSecondary String? // label for the secondary hero button
  galleryImages   String[] @default([]) // public URLs of gallery photos (the shown set)
  hiddenGalleryImages String[] @default([]) // photos kept in the library but hidden from the public gallery
  socialLinks     Json?
  websitePixelId  String?  // which Pixel powers the artist's external website (data-driven install, no redeploy)
  featuredSongIds String[]
  previewSeconds  Int      @default(30)
  unlockGate      String   @default("email") // how a visitor unlocks full songs: "email" | "share" | "follow"
  unlockFollowUrl String?  // for the "follow" gate: the profile URL the visitor is sent to
  fbLikeShare     Boolean  @default(false) // show real Facebook Like & Share buttons on the site
  fbPageUrl       String?  // the artist's Facebook Page URL (target of the Like button)
  // Artist-controlled email settings (Phase 3):
  availableEmails String[] // the mailboxes this artist can pick from (dropdown source)
  contactEmail    String?  // public booking/contact address shown on the site
  notifyEmail     String?  // where new mailing-list signups are reported (internal)
  mailFromEmail   String?  // From address for the artist's outbound mailing-list email
  mailReplyTo     String?  // Reply-To for the artist's outbound mailing-list email
  adRetargetingEnabled Boolean @default(false) // artist opted their fan list into social ad retargeting (Meta Custom Audience). Gated by the global admin toggle too.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([userId])
}

// Per-artist setup/release checklist completion. The task list itself is
// defined in code (src/app/checklist/tasks.ts); this only records which keys an
// artist has marked done. Isolated table so it never touches other queries.
model ChecklistItem {
  id        String   @id @default(cuid())
  userId    String
  key       String
  done      Boolean  @default(false)
  updatedAt DateTime @updatedAt
  @@unique([userId, key])
  @@index([userId])
}

// Third-party ad/analytics pixels the artist wants injected on their external
// website (Meta, TikTok, Google). Isolated table so it never touches other
// queries — the site reads these from config and installs them with no redeploy.
model AdPixel {
  id        String   @id @default(cuid())
  userId    String
  platform  String   // "meta" | "tiktok" | "google"
  pixelId   String
  updatedAt DateTime @updatedAt
  @@unique([userId, platform])
  @@index([userId])
}

// A two-way message between the ArtistOps team (admin) and an approved artist.
// A "thread" is simply all messages sharing a userId. Isolated table.
model Message {
  id        String    @id @default(cuid())
  userId    String // the artist this thread belongs to
  fromAdmin Boolean // true = team → artist, false = artist → team
  body      String
  readAt    DateTime? // when the *recipient* first saw it
  createdAt DateTime  @default(now())
  @@index([userId])
}

// The signup questionnaire, captured while ArtistOps is invite-only. Feeds the
// admin's approval decision. Isolated table — never touched by other queries, so
// it can't break user auth if a column is added later.
model MembershipApplication {
  id          String   @id @default(cuid())
  userId      String?  @unique
  email       String
  role           String // artist | band | manager | label | producer | educator | other
  referredBy     String
  workLink       String?
  goals          String[] @default([])
  catalogSize    String?
  location       String?
  termsAcceptedAt DateTime? // beta as-is disclaimer accepted at signup
  createdAt      DateTime @default(now())
  @@index([email])
}

// An upcoming release fans can ask to be told about. On release day every signup
// gets one email with the link — concentrating plays into the first hours, which
// is the algorithmic signal a new track otherwise has none of.
//
// Not a Spotify pre-save: Spotify's API requires 250k monthly active users for
// the library-write scope, so we own the audience relationship instead.
// Isolated tables — never touched by other queries.
model ReleaseCampaign {
  id          String          @id @default(cuid())
  userId      String
  slug        String          @unique
  title       String
  releaseAt   DateTime // a calendar date — always render in UTC
  linkUrl     String? // where release-day email sends fans (Spotify/smart link)
  status      String          @default("scheduled") // scheduled | announced | canceled
  announcedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  signups     ReleaseNotify[]
  @@index([userId])
}

// One fan waiting on a release. Deduped per campaign so a re-submit is a no-op.
model ReleaseNotify {
  id         String          @id @default(cuid())
  campaignId String
  campaign   ReleaseCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email      String
  status     String          @default("pending") // pending | notified
  createdAt  DateTime        @default(now())
  notifiedAt DateTime?
  @@unique([campaignId, email])
  @@index([campaignId])
}

// A track featured on an artist's public website. Audio lives in the private
// `audio` bucket at previewPath/fullPath; the site streams previews via signed
// URLs and the full track only after an email unlock. Managed per ArtistSite slug.
model SiteTrack {
  id          String   @id @default(cuid())
  userId      String?
  site        String
  songId      String?  // links back to the catalog Song this was featured from
  song        Song?    @relation(fields: [songId], references: [id], onDelete: SetNull)
  trackId     String
  title       String
  order       Int      @default(0)
  gate        String   @default("email") // per-song unlock: "email" | "share" | "follow" | "free"
  previewPath String
  fullPath    String
  durationSec Int?
  streamLinks Json?    // per-song links to monetizing platforms: { spotify?, apple?, amazon?, bandcamp?, youtube?, soundcloud? }
  linksMode   String   @default("default") // when to show this song's streaming links: "default" (use site setting) | "before" | "after" | "off"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([site, trackId])
  @@index([site])
  @@index([userId])
  @@index([songId])
}

// A mailing-list / listener email captured from an artist's public website.
// `site` is the ArtistSite slug. notifyOptIn = true means they explicitly asked
// to hear about future releases and show dates (vs. an email captured only to
// unlock a full track). One email per site.
// A named, saved recipient segment for broadcasts (a saved selection of emails).
model MailingList {
  id        String   @id @default(cuid())
  userId    String
  name      String
  emails    String[] // selected subscriber emails
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, name])
  @@index([userId])
}

model MailingSubscriber {
  id             String    @id @default(cuid())
  userId         String?
  site           String
  email          String
  name           String?
  notifyOptIn    Boolean   @default(false)
  source         String?
  adOptOut       Boolean   @default(false) // fan opted out of ad-audience matching (Meta) but still wants email
  unsubscribed   Boolean   @default(false) // opted out (only the listener can undo, by re-signing up)
  unsubscribedAt DateTime?
  unsubToken     String?   @unique // one-click unsubscribe token (set when first emailed)
  resubscribed   Boolean   @default(false) // was unsubscribed, then signed up again
  deleted        Boolean   @default(false) // soft-deleted by the artist (reversible)
  deletedAt      DateTime?
  signupCount    Int       @default(1) // # of signup submissions (debug play-gate re-subs)
  blockedAttempts Int      @default(0) // website signups attempted while deleted (blocked)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  @@unique([site, email])
  @@index([userId])
  @@index([site])
}
